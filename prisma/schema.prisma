generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Audit {
  id              String   @id @default(cuid())
  url             String
  platform        String
  score           Int
  categoryScores  String
  results         String
  paid            Boolean  @default(false)
  pdfZhGenerated  Boolean  @default(false)
  pdfEnGenerated  Boolean  @default(false)
  stripeSessionId String?
  ipAddress       String?
  locale          String   @default("zh")
  createdAt       DateTime @default(now())
  expiresAt       DateTime

  @@index([url])
  @@index([stripeSessionId])
}

model RateLimit {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  count     Int      @default(1)
  resetAt   DateTime
}

model EmailLead {
  id        String   @id @default(cuid())
  email     String
  auditId   String
  locale    String   @default("zh")
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([auditId])
}
